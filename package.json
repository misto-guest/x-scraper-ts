{
  "name": "x-scraper-ts",
  "version": "1.0.0",
  "description": "Twitter/X scraper using TypeScript + Puppeteer-core + AdsPower",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "twitter",
    "scraper",
    "puppeteer",
    "adspower"
  ],
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "node-fetch": "^3.3.2",
    "puppeteer-core": "^22.0.0",
    "sql.js": "^1.10.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/puppeteer-core": "^5.4.0",
    "@types/sql.js": "^1.4.9",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
